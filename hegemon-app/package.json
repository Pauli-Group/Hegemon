{
  "name": "hegemon-app",
  "private": true,
  "version": "0.10.0",
  "description": "Desktop wallet and node console for the Hegemon 0.10 network.",
  "author": "Hegemon",
  "type": "module",
  "main": "out/main/main.cjs",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "build": "electron-vite build",
    "package": "electron-vite build && electron-builder --dir",
    "dist": "electron-vite build && electron-builder",
    "dist:prod": "node scripts/require-prod-release-env.cjs && electron-vite build && electron-builder",
    "check:launch-autostart": "node ../scripts/check-app-launch-autostart.mjs",
    "check:ui-guards": "node scripts/check-ui-guards.mjs",
    "preview": "electron-vite preview",
    "lint": "npm run typecheck",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "hash-wasm": "^4.12.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@types/node": "^20.17.30",
    "@types/react": "^18.3.20",
    "@types/react-dom": "^18.3.5",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^39.8.10",
    "electron-builder": "^26.6.0",
    "electron-vite": "^5.0.0",
    "postcss": "^8.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.8.2",
    "vite": "^7.3.1",
    "vitest": "^4.1.10"
  },
  "build": {
    "appId": "com.hegemon.desktop",
    "productName": "Hegemon",
    "afterPack": "scripts/after-pack.cjs",
    "afterSign": "scripts/after-sign.cjs",
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "out/**",
      "node_modules/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "../target/release/hegemon-node",
        "to": "bin/hegemon-node"
      },
      {
        "from": "../target/release/walletd",
        "to": "bin/walletd"
      },
      {
        "from": "build/icon.png",
        "to": "icon.png"
      },
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      },
      {
        "from": "build/icon.icns",
        "to": "icon.icns"
      }
    ],
    "mac": {
      "icon": "build/icon.icns",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.finance",
      "extendInfo": {
        "NSAppTransportSecurity": {
          "NSAllowsArbitraryLoads": false,
          "NSAllowsLocalNetworking": true,
          "NSExceptionDomains": {
            "127.0.0.1": {
              "NSIncludesSubdomains": false,
              "NSTemporaryExceptionAllowsInsecureHTTPLoads": true,
              "NSTemporaryExceptionAllowsInsecureHTTPSLoads": false,
              "NSTemporaryExceptionRequiresForwardSecrecy": false
            },
            "localhost": {
              "NSIncludesSubdomains": false,
              "NSTemporaryExceptionAllowsInsecureHTTPLoads": true,
              "NSTemporaryExceptionAllowsInsecureHTTPSLoads": false,
              "NSTemporaryExceptionRequiresForwardSecrecy": false
            }
          }
        },
        "NSAudioCaptureUsageDescription": "Hegemon does not use audio capture.",
        "NSBluetoothAlwaysUsageDescription": "Hegemon does not use Bluetooth.",
        "NSBluetoothPeripheralUsageDescription": "Hegemon does not use Bluetooth.",
        "NSCameraUsageDescription": "Hegemon does not use camera access.",
        "NSMicrophoneUsageDescription": "Hegemon does not use microphone access."
      }
    },
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "nsis",
        "zip"
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Finance"
    }
  }
}
